{
  "name": "@sugardarius/anzen",
  "version": "2.3.2",
  "description": "Fast, flexible, framework validation agnostic, type‑safe factories for creating server actions, route handlers, page and layout Server Component files in Next.js.",
  "license": "MIT",
  "packageManager": "pnpm@11.10.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "module": "./dist/index.js",
        "default": "./dist/index.cjs"
      }
    },
    "./server-components": {
      "import": {
        "types": "./dist/server-components/index.d.ts",
        "default": "./dist/server-components/index.js"
      },
      "require": {
        "types": "./dist/server-components/index.d.cts",
        "module": "./dist/server-components/index.js",
        "default": "./dist/server-components/index.cjs"
      }
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "author": {
    "name": "Aurélien Dupays Dexemple",
    "url": "https://aureliendupaysdexemple.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SugarDarius/anzen"
  },
  "bugs": {
    "url": "https://github.com/SugarDarius/anzen/issues"
  },
  "keywords": [
    "nextjs",
    "safe server actions",
    "safe route handlers",
    "safe page server components",
    "safe layout server components",
    "framework agnostic validation",
    "type-safe validation",
    "type-safe authorization"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup --minify",
    "dev:www": "turbo run dev --filter=www",
    "build:www": "turbo run build --filter=www",
    "test": "vitest run --silent",
    "lint": "pnpm run lint:eslint && pnpm run lint:tsc && pnpm run lint:package",
    "lint:eslint": "eslint src/",
    "lint:tsc": "tsc --noEmit",
    "lint:package": "publint --strict && attw --pack . --profile node16",
    "format": "prettier --write src/",
    "release": "release-it",
    "postinstall": "syncpack lint"
  },
  "peerDependencies": {
    "next": "^16 || ^15 || ^14"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@eslint/eslintrc": "catalog:",
    "@eslint/js": "catalog:",
    "@release-it/keep-a-changelog": "^7.1.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "decoders": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "publint": "^0.3.21",
    "release-it": "^20.2.1",
    "tsup": "^8.5.1",
    "turbo": "^2.10.4",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "^4.1.10",
    "zod": "catalog:"
  },
  "dependencies": {
    "syncpack": "^15.3.2"
  }
}
