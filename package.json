{
  "name": "@sugardarius/anzen",
  "version": "2.3.2",
  "description": "Fast, flexible, framework validation agnostic, type‑safe factories for creating server actions, route handlers, page and layout Server Component files in Next.js.",
  "keywords": [
    "framework agnostic validation",
    "nextjs",
    "safe layout server components",
    "safe page server components",
    "safe route handlers",
    "safe server actions",
    "type-safe authorization",
    "type-safe validation"
  ],
  "bugs": {
    "url": "https://github.com/SugarDarius/anzen/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Aurélien Dupays Dexemple",
    "url": "https://aureliendupaysdexemple.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SugarDarius/anzen"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "module": "./dist/index.js",
        "default": "./dist/index.cjs"
      }
    },
    "./server-components": {
      "import": {
        "types": "./dist/server-components/index.d.ts",
        "default": "./dist/server-components/index.js"
      },
      "require": {
        "types": "./dist/server-components/index.d.cts",
        "module": "./dist/server-components/index.js",
        "default": "./dist/server-components/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup --minify",
    "dev:www": "turbo run dev --filter=www",
    "build:www": "turbo run build --filter=www",
    "test": "vitest run --silent",
    "lint": "pnpm run lint:check && pnpm run lint:tsc && pnpm run lint:package",
    "lint:check": "ultracite check --no-error-on-unmatched-pattern",
    "lint:tsc": "tsc --noEmit",
    "lint:package": "publint --strict && attw --pack . --profile node16",
    "lint:fix": "ultracite fix --no-error-on-unmatched-pattern",
    "release": "release-it",
    "postinstall": "syncpack lint"
  },
  "dependencies": {
    "syncpack": "^15.3.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@release-it/keep-a-changelog": "^7.1.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "decoders": "catalog:",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "publint": "^0.3.21",
    "react": "catalog:",
    "release-it": "^20.2.1",
    "tsup": "^8.5.1",
    "turbo": "^2.10.5",
    "typescript": "catalog:",
    "ultracite": "^7.9.4",
    "vitest": "^4.1.10",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "next": "^16 || ^15 || ^14"
  },
  "packageManager": "pnpm@11.13.0"
}
